generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RawNote {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  noteDate  DateTime
  source    String?
  company   String?
  persona   String?
  workload  String?
  rawText   String

  brief         Brief?
  signals       Signal[]
  sourceResults SourceResult[]
}

model Signal {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  rawNoteId String
  rawNote   RawNote @relation(fields: [rawNoteId], references: [id], onDelete: Cascade)

  source                String?
  company               String?
  persona               String?
  workload              String?
  currentSystem         String?
  painCategory          String?
  pain                  String?
  competitor            String?
  exactCustomerLanguage String?
  productConfusion      String?
  docsGap               String?
  salesEnablementNeed   String?
  productFeedback       String?
  businessImplication   String?
  suggestedAction       String?
  confidence            Int?
  sourceQuality         String?
  signalType            String?

  @@index([rawNoteId])
}

model SourceSearchRun {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  watchlistId String?
  watchlist   Watchlist? @relation(fields: [watchlistId], references: [id], onDelete: SetNull)

  sourceType String
  query      String
  since      DateTime?
  until      DateTime?
  limit      Int?

  results SourceResult[]

  @@index([watchlistId])
}

model SourceResult {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  searchRunId String
  searchRun   SourceSearchRun @relation(fields: [searchRunId], references: [id], onDelete: Cascade)

  sourceType   String
  sourceName   String?
  title        String?
  url          String?
  author       String?
  channel      String?
  publishedAt  DateTime?
  capturedAt   DateTime @default(now())
  text         String
  metadataJson Json?

  rawNoteId String?
  rawNote   RawNote? @relation(fields: [rawNoteId], references: [id], onDelete: SetNull)

  @@index([searchRunId])
  @@index([rawNoteId])
}

model Brief {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  rawNoteId String  @unique
  rawNote   RawNote @relation(fields: [rawNoteId], references: [id], onDelete: Cascade)

  title                 String?
  strongestMarketSignal String?
  topSignalsJson        Json
  repeatedPainsJson     Json
  customerLanguageJson  Json
  competitorsJson       Json
  productConfusionJson  Json
  docsGapsJson          Json
  salesEnablementJson   Json
  productFeedbackJson   Json
  recommendedAction     String?
  pmmTakeaway           String?
  fullMarkdown          String

  actionItems ActionItem[]
}

model Watchlist {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String
  category    String
  sourceType  String
  query       String
  cadence     String
  enabled     Boolean @default(true)
  limit       Int     @default(10)
  lookbackDays Int    @default(7)

  lastRunAt DateTime?
  nextRunAt DateTime?
  lastError String?

  runs SourceSearchRun[]

  @@index([enabled, nextRunAt])
  @@index([category])
}

model IntelligenceReport {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  reportType  String
  periodStart DateTime
  periodEnd   DateTime

  title                String?
  summary              String
  learnedJson          Json
  repeatedPainsJson    Json
  competitorsJson      Json
  productConfusionJson Json
  recommendedActionsJson Json
  salesNotesJson       Json
  productNotesJson     Json
  sourceRunIdsJson     Json?
  fullMarkdown         String

  actionItems ActionItem[]

  @@index([reportType, createdAt])
}

model ActionItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reportId String?
  report   IntelligenceReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)

  briefId String?
  brief   Brief? @relation(fields: [briefId], references: [id], onDelete: SetNull)

  origin         String  @default("report")
  title          String
  recommendation String
  rationale      String?
  owner          String?
  useFor         String?
  status         String  @default("new")
  evidenceJson   Json?

  @@index([status])
  @@index([reportId])
  @@index([briefId])
}
