generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RawNote {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  noteDate  DateTime
  source    String?
  company   String?
  persona   String?
  workload  String?
  rawText   String

  brief         Brief?
  signals       Signal[]
  sourceResults SourceResult[]
}

model Signal {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  rawNoteId String
  rawNote   RawNote @relation(fields: [rawNoteId], references: [id], onDelete: Cascade)

  source                String?
  company               String?
  persona               String?
  workload              String?
  currentSystem         String?
  painCategory          String?
  pain                  String?
  competitor            String?
  exactCustomerLanguage String?
  productConfusion      String?
  docsGap               String?
  salesEnablementNeed   String?
  productFeedback       String?
  businessImplication   String?
  suggestedAction       String?
  confidence            Int?
  sourceQuality         String?
  signalType            String?

  @@index([rawNoteId])
}

model SourceSearchRun {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  sourceType String
  query      String
  since      DateTime?
  until      DateTime?
  limit      Int?

  results SourceResult[]
}

model SourceResult {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  searchRunId String
  searchRun   SourceSearchRun @relation(fields: [searchRunId], references: [id], onDelete: Cascade)

  sourceType   String
  sourceName   String?
  title        String?
  url          String?
  author       String?
  channel      String?
  publishedAt  DateTime?
  capturedAt   DateTime @default(now())
  text         String
  metadataJson Json?

  rawNoteId String?
  rawNote   RawNote? @relation(fields: [rawNoteId], references: [id], onDelete: SetNull)

  @@index([searchRunId])
  @@index([rawNoteId])
}

model Brief {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  rawNoteId String  @unique
  rawNote   RawNote @relation(fields: [rawNoteId], references: [id], onDelete: Cascade)

  title                 String?
  strongestMarketSignal String?
  topSignalsJson        Json
  repeatedPainsJson     Json
  customerLanguageJson  Json
  competitorsJson       Json
  productConfusionJson  Json
  docsGapsJson          Json
  salesEnablementJson   Json
  productFeedbackJson   Json
  recommendedAction     String?
  pmmTakeaway           String?
  fullMarkdown          String
}
