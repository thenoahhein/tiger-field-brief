# Postgres connection string used by Prisma
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# LLM provider. Supported: "anthropic" (default) or "openai".
LLM_PROVIDER="anthropic"

# Anthropic (Claude) API key — used when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY="sk-ant-..."
# Optional: override the model (default: claude-3-5-sonnet-latest)
# ANTHROPIC_MODEL="claude-3-5-sonnet-latest"

# OpenAI API key — used when LLM_PROVIDER=openai
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o-mini"

# --- External sources (all OPTIONAL, read-only, server-side only) -----------
# Any source left unset shows as "Not configured" on /sources and is skipped.

# Web search. Provider: tavily (default) | brave | serper
# WEB_SEARCH_PROVIDER="tavily"
# WEB_SEARCH_API_KEY=""
# Optional: override the provider host (proxy / self-hosted gateway / testing).
# WEB_SEARCH_BASE_URL=""

# X (Twitter) via an MCP server — search/read only.
# X_MCP_SERVER_URL=""
# X_MCP_AUTH_TOKEN=""
# Optional: explicit search tool name if auto-detection fails.
# X_MCP_SEARCH_TOOL=""

# Slack — read only. Prefer MCP; otherwise a search-capable Web API token.
# SLACK_MCP_SERVER_URL=""
# SLACK_MCP_AUTH_TOKEN=""
# Optional: explicit Slack MCP search tool name.
# SLACK_MCP_SEARCH_TOOL=""
# Web API mode: search.messages requires a user token (xoxp-…) with search:read.
# SLACK_BOT_TOKEN=""
